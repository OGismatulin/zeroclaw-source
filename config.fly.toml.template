    "file_read",
    "file_write",
    "memory_recall",
    "shell",
    "http_request",
]
always_ask = []
allowed_roots = ["/zeroclaw-data/code-repos"]
non_cli_excluded_tools = []

[mcp]
enabled = true
deferred_loading = false

