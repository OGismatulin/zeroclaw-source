    "lalafo-db__ch_tables", "lalafo-db__query_to_file", "lalafo-db__ch_query_to_file", "lalafo-db__health",
    "graylog__health", "graylog__count", "graylog__search", "graylog__by_request_id",
    "graylog__by_user", "graylog__search_to_file",
]

[risk_profiles.default.delegation_policy]
mode = "allow"

# ── Runtime profiles ──────────────────────────────────────────────────────
# Replaces the pre-V3 top-level [agent] block. context_compression +
# model_windows are nested here (V3 home — a top-level [agent] section would be
# silently ignored by the V3 runtime). summary_model intentionally unset so the
# summarizer uses the session's current main model (webhook /model switching).

[runtime_profiles.default]
agentic = true
compact_context = false
max_tool_iterations = 200
# max_actions_per_hour: per-sender sliding-window cap on "act" tool ops
# (shell/file_write/http_request/notify/send_file). Absent → schema default 20,
# which throttled heavy cron digests + at/after jobs once patch #17 raised the
# iteration cap 10→200 and turns finally reached 20+ act-ops mid-turn (the
# "action budget exhausted" / "Файл отправится после снятия rate limit" symptom).
# Set effectively-unlimited for background/cron and interactive turns alike.
max_actions_per_hour = 1_000_000
max_history_messages = 200
max_context_tokens = 128_000
parallel_tools = true
tool_dispatcher = "native"
shell_timeout_secs = 600

[runtime_profiles.default.context_compression]
threshold_ratio = 0.70
protect_last_n = 10

[runtime_profiles.default.context_compression.model_windows]
"mimo-v2.5-pro"           = 800_000
"mimo-v2.5"               = 800_000
"deepseek-v4-flash"       = 800_000
"deepseek-v4-pro"         = 800_000
"gemini-3-flash-preview"  = 800_000
"qwen3.7-plus"            = 1_000_000
"minimax-m3"              = 1_000_000
"glm-5.2"                 = 1_000_000
"glm-5.2-fast"            = 1_048_576
"kimi-k2.7-code"          = 256_000
"minimax-m2.7"            = 196_608
"gpt-5.5"                 = 400_000
"gpt-5.4"                 = 400_000
"gpt-5.4-mini"            = 400_000
"glm-5-turbo"             = 128_000
"glm-5.1"                 = 202_752
# Capital "GLM-5.1" is a separate case-sensitive key (model string ships as-is;
# model_windows.get() is case-sensitive). Same ZhiPu GLM-5.1, same ~200K window.
"GLM-5.1"                 = 202_752
"Qwen3.5-397B-A17B"       = 262_144

