# Native schema_version = 3 config (Fly volume seed for fresh deploys).
#
# Pre-V3 configs were V1→V3 migrated in-memory every boot; this template is
# authored natively in V3 shape so no migration runs. Spike 0 proved a
# hand-authored native-V3 config boots and resolves the boot-provider
# deterministically from [providers.models.opencode.go].
#
# Secret placeholders __ZEROCLAW_BEARER_TOKEN__ / __ZEROCLAW_WEBHOOK_SECRET__
# are substituted by the entrypoint/init sed at deploy time. api_key = "" stays
# empty everywhere (credentials resolve through env / Fly secrets), so a
# provider-specific placeholder never leaks to another provider.
schema_version = 3

# ── Providers ───────────────────────────────────────────────────────────────
# Boot-default = [providers.models.opencode.go]. normalize_provider_type(
# "opencode-go", "default") → opencode.go; the synthesized agents.default points
# its model_provider here. Model lives on the entry, NOT in ZEROCLAW_MODEL (V3
# ignores that env override).

[providers.models.opencode.go]
model = "deepseek-v4-flash"
uri = "https://opencode.ai/zen/go/v1"
api_key = ""
# Go-router accepts reasoning_effort in the request body; deepseek gates the
# structured field to None, so we pass it via provider_extra (flattens into the
# body top-level). Separate knob from codex — config.runtime.reasoning_effort
# stays unset (codex default xhigh). Only low/medium/high/xhigh/max — NOT minimal (400).
provider_extra = { reasoning_effort = "high" }

# Isolated coordinator alias: same deepseek-v4-flash on the same Go endpoint, but
# reasoning_effort = "max" (Go-router valid — NOT minimal→400). Only
# [agents.jira_coordinator] points here; worker/default/jira_worker stay on
# opencode.go (high). Rollback = repoint jira_coordinator back to opencode.go and
# bump the marker. Spec: 2026-07-24-jira-judge-ensemble-input-integrity §5.3.
[providers.models.opencode.go_coordinator]
model = "deepseek-v4-flash"
uri = "https://opencode.ai/zen/go/v1"
api_key = ""
provider_extra = { reasoning_effort = "max" }

# Subagent analyst_mimo runs mimo-v2.5-pro on the same opencode-go endpoint.
[providers.models.opencode.mimo]
model = "mimo-v2.5-pro"
uri = "https://opencode.ai/zen/go/v1"
api_key = ""

# Codex subagents fold under the `openai` family with the codex OAuth runtime
# (wire_api = "responses" + requires_openai_auth = true — what the V1→V3
# migration applies to "openai-codex"). worker = gpt-5.6-luna (cheap GPT-5.6
# tier; reachable on Codex only via fork patch #22 originator=codex_cli_rs —
# 404 under the old `pi` identity), coder = gpt-5.5.
[providers.models.openai.codex_worker]
model = "gpt-5.6-luna"
api_key = ""
wire_api = "responses"
requires_openai_auth = true

[providers.models.openai.codex_coder]
model = "gpt-5.5"
api_key = ""
wire_api = "responses"
requires_openai_auth = true

# GPT-5.6 analyst slots on the same codex OAuth runtime (GA on Codex
# 2026-07-09). sol = frontier tier, terra = balance tier (≈5.5 quality,
# 2x cheaper). Referenced by [agents.analyst_sol] / [agents.analyst_terra].
[providers.models.openai.codex_sol]
model = "gpt-5.6-sol"
api_key = ""
wire_api = "responses"
requires_openai_auth = true

[providers.models.openai.codex_terra]
model = "gpt-5.6-terra"
api_key = ""
wire_api = "responses"
requires_openai_auth = true

# deepseek subagents: pro (deepseek-v4-pro) and flash (deepseek-v4-flash).
[providers.models.deepseek.pro]
model = "deepseek-v4-pro"
api_key = ""

[providers.models.deepseek.flash]
model = "deepseek-v4-flash"
api_key = ""

[providers.models.zai.default]
model = "glm-5.2"
api_key = ""

# Bootstrap reference for fresh deploys; production overrides provider/model in
# fly.toml [env] (but V3 ignores ZEROCLAW_MODEL — boot default is opencode.go).
[providers.models.openrouter.default]
model = "google/gemini-3-flash-preview"
api_key = ""

[providers.models.minimax.default]
model = "minimax-m2.7"
api_key = ""

# Custom-URL provider (Cline / api.cline.bot, OpenAI-compatible). Replaced
# neuralwatt 2026-07-23 (neuralwatt no longer used). Reached ONLY via the bot's
# per-request /model override (provider="custom.cline"); not the daemon default.
# NO `model` key on purpose: a pinned model would make ModelPinnedProvider rewrite
# every request to it — without it the request model flows through (the four
# ClinePass slugs cline-pass/{glm-5.2,kimi-k3,qwen3.7-max,minimax-m3}). Key via env
# ZEROCLAW_API_KEY (generic fallback slot for the custom family; = the Cline key).
# Cline wraps non-streaming responses in {"data":{choices},"success"} — the fork
# patch in compatible.rs (parse_chat_response_body) unwraps that envelope.
# Spec: docs/superpowers/specs/2026-07-23-cline-provider-and-jira-analyst-design.md
[providers.models.custom.cline]
uri = "https://api.cline.bot/api/v1"
api_key = ""
# Cline supports native OpenAI tool-calling (verified via curl, all 4 models).
# The custom family disables native tools by default (text <tool_call> protocol),
# which leaks raw markup to the user (prod incident 2026-06-20). Opt back in.
native_tools = true
# NO per-alias `fallback`: v0.8.2 broke the alias fallback-build path
# (create_resilient_model_provider_for_alias -> append_fallback_chain) — it demands a
# "profile-resolved credential" and can't resolve opencode.go's env key, so a
# `fallback = [...]` here makes the WHOLE override init fail ("failed to init override
# provider") -> hard "временно недоступен" on EVERY request (prod incident 2026-07-09).
# Trade-off: a real Cline 429 hard-fails instead of degrading to deepseek.

# Pinned Cline alias for the analyst_qwen subagent (Jira ensemble). Unlike the
# flow-through alias above, this one MUST pin `model`: subagents resolve their
# model from the provider entry. The ClinePass slug cline-pass/qwen3.7-max is
# native tool-calling smoke-verified (ClinePass subscription tract; the earlier
# pay-as-you-go id format returned 402 insufficient_credits — 2026-07-24). kimi
# was swapped out earlier for being too slow. NO fallback — preserves the analyst
# failure domain (jira-analysis-pipeline D2: same-provider retry x3, no fallback).
[providers.models.custom.cline_qwen]
model = "cline-pass/qwen3.7-max"
uri = "https://api.cline.bot/api/v1"
api_key = ""
native_tools = true

# ── Reliability ───────────────────────────────────────────────────────────
[reliability]
fallback_providers = ["opencode-go"]

[reliability.model_fallbacks]
# Phase 1 (2026-05-22) — Bot UX catalog primary entries (8)
"GLM-5.1"            = ["deepseek-v4-flash"]
"Qwen3.5-397B-A17B"  = ["deepseek-v4-flash"]
"gpt-5.5"            = ["deepseek-v4-flash"]
"gpt-5.4"            = ["deepseek-v4-flash"]
"gpt-5.4-mini"       = ["deepseek-v4-flash"]
# GPT-5.6 codex family (2026-07-09 GA on Codex) — sol/terra/luna
# (gpt-5.6-luna: id confirmed correct + on the same Codex SKU as terra (which works),
#  but chatgpt.com Codex backend 404'd it during GA rollout 2026-07-10 — self-heals
#  when OpenAI's 24h rollout reaches our endpoint; degrades to deepseek meanwhile.)
"gpt-5.6-sol"        = ["deepseek-v4-flash"]
"gpt-5.6-terra"      = ["deepseek-v4-flash"]
"gpt-5.6-luna"       = ["deepseek-v4-flash"]
"glm-5-turbo"        = ["deepseek-v4-flash"]
"glm-5.1"            = ["deepseek-v4-flash"]
"minimax-m2.7"       = ["deepseek-v4-flash"]
# Go-plan native opencode-go (2026-06-15) — re-synced to current Go catalog
# Spec: docs/superpowers/specs/2026-06-15-opencode-go-go-plan-catalog-sync-design.md
"mimo-v2.5-pro"      = ["deepseek-v4-flash"]
"mimo-v2.5"          = ["deepseek-v4-flash"]
"deepseek-v4-pro"    = ["deepseek-v4-flash"]
"qwen3.7-plus"       = ["deepseek-v4-flash"]
"minimax-m3"         = ["deepseek-v4-flash"]
"kimi-k2.7-code"     = ["deepseek-v4-flash"]
"glm-5.2"            = ["deepseek-v4-flash"]

# ── Memory ──────────────────────────────────────────────────────────────────
[memory]
backend = "sqlite"
auto_save = true
embedding_provider = "openrouter"
embedding_model = "openai/text-embedding-3-small"
embedding_dimensions = 1536
# Core-memory durability: export category='core' → MEMORY_SNAPSHOT.md at each
# daemon spawn; auto_hydrate (default true) restores on cold-boot.
snapshot_enabled = true
snapshot_on_hygiene = true
# Native per-turn consolidation (fork): each answered turn → Daily history_entry
# + Core memory_update with conflict dedup (superseded_by). On by default (since
# 2026-06-17; serde default also true). Set false to opt a user out. Coexists
# with nightly-retrospective.
# Spec: docs/superpowers/specs/2026-06-16-native-per-turn-consolidation-design.md
consolidation_enabled = true

# sqlite_open_timeout_secs moved to [storage.<backend>.<alias>] in V3; [memory]
# backend = "sqlite" resolves to sqlite.default.
[storage.sqlite.default]
open_timeout_secs = 30

# ── Skills ──────────────────────────────────────────────────────────────────
[skills]
prompt_injection_mode = "compact"

# ── Observability ───────────────────────────────────────────────────────────
# MANDATORY (Spike 0): without it runtime-trace.jsonl stops writing and later
# gates fail. V3 field names log_persistence* are aliases of the old
# runtime_trace_* keys.
[observability]
backend = "none"
log_persistence = "rolling"
log_persistence_path = "logs/runtime-trace.jsonl"
log_persistence_max_entries = 5000

# ── Gateway ───────────────────────────────────────────────────────────────
# require_pairing = false (Spike 0): else child daemons 401 the manager's
# forwarded bearer token.
[gateway]
port = 3000
host = "127.0.0.1"
require_pairing = false
allow_public_bind = false
paired_tokens = ["__ZEROCLAW_BEARER_TOKEN__"]
trust_forwarded_headers = false
pair_rate_limit_per_minute = 0
webhook_rate_limit_per_minute = 0
rate_limit_max_keys = 10000
idempotency_ttl_secs = 300
idempotency_max_keys = 10000
# Webhook turns run long (heavy tool loops); pin the timeout in typed config
# instead of the former env-first fork shim. Fly still sets
# ZEROCLAW_GATEWAY_TIMEOUT_SECS for the Python manager's own request timeout.
request_timeout_secs = 1800
long_running_request_timeout_secs = 600

# Tunnel defaults to "none" in V3 (tunnel.tunnel_provider); no section needed.

# Webhook section stays spelled [channels_config.webhook]: the V3 runtime treats
# it as a legacy section and skips it (the embedded webhook channel is dead code
# here — the live path is the gateway crate's handle_webhook bound to [gateway]
# port), but gateway_manager._rewrite_gateway_config matches this literal block
# to inject each daemon's per-user port. Keep the literal name (do NOT rename to
# [channels.webhook.default] — that breaks the manager's port rewrite).
[channels_config]
cli = true

[channels_config.webhook]
port = 3000
secret = "__ZEROCLAW_WEBHOOK_SECRET__"

# ── Multimodal ──────────────────────────────────────────────────────────────
[multimodal]
max_images = 4
max_image_size_mb = 20
vision_provider = "openrouter"
vision_model = "google/gemini-3.1-flash-lite-preview"

# ── HTTP request tool ─────────────────────────────────────────────────────
[http_request]
enabled = true
allowed_domains = ["*"]
max_response_size = 100000
timeout_secs = 30

# ── Jira tool ───────────────────────────────────────────────────────────────
[jira]
enabled = true
base_url = "https://yallaclassifieds.atlassian.net"
email = "oleg.gismatulin@lalafo.com"
api_token = ""
allowed_actions = ["get_ticket", "search_tickets", "comment_ticket"]
timeout_secs = 30

# ── Delegate ──────────────────────────────────────────────────────────────
[delegate]
timeout_secs = 90
agentic_timeout_secs = 3600
# Server-side long-poll (seconds) for check_result on a still-Running task:
# waits up to this long, re-reading status every ~5s, returns early on
# terminal/reconciled-loss. Bounds orchestrator poll frequency so a slow
# sub-agent can't drain max_iterations before the coordinator launches
# downstream work (DV-34312). 0 = off (immediate return). Range 0..=300.
check_result_long_poll_secs = 60

# ── Heartbeat ─────────────────────────────────────────────────────────────
# Periodic HEARTBEAT.md tasks (e.g. Jira watchdog). V3 made `enabled` default
# false and `agent` required (must name a configured agent). agent = "default"
# = the synthesized main agent. interval/two_phase set explicitly so an
# upstream default-flip can't silently disable us again.
[heartbeat]
enabled = true
agent = "default"
interval_minutes = 30
two_phase = true

# ── MCP ─────────────────────────────────────────────────────────────────────
[mcp]
enabled = true
deferred_loading = false

[[mcp.servers]]
name = "context7"
transport = "http"
url = "https://mcp.context7.com/mcp"
tool_timeout_secs = 60

[[mcp.servers]]
name = "lalafo-db"
transport = "http"
url = "http://localhost:4000/mcp"
tool_timeout_secs = 120

[[mcp.servers]]
name = "graylog"
transport = "http"
url = "http://localhost:4001/mcp"
tool_timeout_secs = 120

# codemap-semantic: second remote MCP on the SAME box — natural-language semantic
# search over the monorepa (claude-context + Zilliz), for "how does X work / where is
# the logic for Y" where the symbol name is unknown. Its [mcp.servers.headers] MUST sit
# immediately below THIS block (headers attach to the last [[mcp.servers]]). Bearer seeded
# from CODEMAP_SEMANTIC_API_KEY via placeholder. Design: docs/superpowers/specs/2026-07-07-*.
[[mcp.servers]]
name = "codemap-semantic"
transport = "http"
url = "https://178-104-197-112.sslip.io/semantic/mcp"
tool_timeout_secs = 120

[mcp.servers.headers]
Authorization = "Bearer __CODEMAP_SEMANTIC_API_KEY__"

# codemap-fs: third remote MCP on the SAME box — read-only file access to the
# indexed monorepa (services/packages/prototypes) so the agent reads a file or a
# project's CLAUDE.md/README.md directly instead of hunting via glab api. Its
# [mcp.servers.headers] MUST sit immediately below THIS block (headers attach to
# the last [[mcp.servers]]). REUSES CODEMAP_API_KEY (Oleg #2 — one key, three
# routes). Design: docs/superpowers/specs/2026-07-15-*.
[[mcp.servers]]
name = "codemap-fs"
transport = "http"
url = "https://178-104-197-112.sslip.io/fs/mcp"
tool_timeout_secs = 120

[mcp.servers.headers]
Authorization = "Bearer __CODEMAP_API_KEY__"

# codemap: remote code-index MCP over the internet (Fly iad -> Hetzner EU).
# graph of the Lalafo monorepa (graphify). Bearer secret is seeded from
# CODEMAP_API_KEY via the __CODEMAP_API_KEY__ placeholder (no env-subst in
# MCP headers — mcp_transport.rs). Design: docs/superpowers/specs/2026-07-06-*.
[[mcp.servers]]
name = "codemap"
transport = "http"
url = "https://178-104-197-112.sslip.io/mcp"
tool_timeout_secs = 120

# WARNING: this sub-table attaches to the LAST mcp.servers entry above (codemap).
# Add new MCP servers ABOVE the codemap block, or move these headers with it.
[mcp.servers.headers]
Authorization = "Bearer __CODEMAP_API_KEY__"

# ── MCP bundles ─────────────────────────────────────────────────────────────
# v0.8.2 is secure-by-default: an agent with no `mcp_bundles` receives NO MCP
# servers (omission is not a grant — schema.rs mcp_servers_for_bundles). Pre-v0.8.2
# every agent got every [[mcp.servers]] globally; this bundle + per-agent
# `mcp_bundles = ["all"]` below restores that. Names match [[mcp.servers]].name.
[mcp_bundles.all]
servers = ["context7", "lalafo-db", "graylog", "codemap", "codemap-semantic", "codemap-fs"]

# ── Risk profile (default) ──────────────────────────────────────────────────
