api_key = ""
default_provider = "openrouter"
default_model = "google/gemini-3-flash-preview"
default_temperature = 0.7

[reliability]
fallback_providers = ["opencode-go"]

[reliability.model_fallbacks]
# Phase 1 (2026-05-22) — Bot UX catalog primary entries (8)
"GLM-5.1"            = ["deepseek-v4-flash"]
"Qwen3.5-397B-A17B"  = ["deepseek-v4-flash"]
"gpt-5.5"            = ["deepseek-v4-flash"]
"gpt-5.4"            = ["deepseek-v4-flash"]
"gpt-5.4-mini"       = ["deepseek-v4-flash"]
"glm-5-turbo"        = ["deepseek-v4-flash"]
"glm-5.1"            = ["deepseek-v4-flash"]
"minimax-m2.7"       = ["deepseek-v4-flash"]
# Phase 2 (2026-05-28) — Native opencode-go models
# Each model routes to a different upstream provider via opencode-go router;
# upstream outage isolation makes deepseek-v4-flash a safe fallback (via DeepSeek upstream).
# Middle-loop dedup in lib.rs:1868-1869 — no extra HTTP overhead.
# Spec: docs/superpowers/specs/2026-05-28-opencode-go-native-fallback-design.md
"mimo-v2.5-pro"      = ["deepseek-v4-flash"]
"mimo-v2.5"          = ["deepseek-v4-flash"]
"mimo-v2-pro"        = ["deepseek-v4-flash"]
"mimo-v2-omni"       = ["deepseek-v4-flash"]
"glm-5"              = ["deepseek-v4-flash"]
"minimax-m2.5"       = ["deepseek-v4-flash"]
"kimi-k2.5"          = ["deepseek-v4-flash"]
"qwen3.6-plus"       = ["deepseek-v4-flash"]
# 2026-05-29 — analyst ensemble (deepseek-v4-pro has no native upstream fallback)
"deepseek-v4-pro"    = ["deepseek-v4-flash"]

[memory]
backend = "sqlite"
auto_save = true
embedding_provider = "openrouter"
embedding_model = "openai/text-embedding-3-small"
embedding_dimensions = 1536
sqlite_open_timeout_secs = 30

[agent]
compact_context = false
max_tool_iterations = 50
max_history_messages = 200
max_context_tokens = 128_000
parallel_tools = true
tool_dispatcher = "native"

[agent.context_compression]
threshold_ratio = 0.70
protect_last_n = 10

[agent.context_compression.model_windows]
"mimo-v2.5-pro"           = 800_000
"mimo-v2.5"               = 800_000
"mimo-v2-pro"             = 800_000
"mimo-v2-omni"            = 800_000
"deepseek-v4-flash"       = 800_000
"deepseek-v4-pro"         = 800_000
"gemini-3-flash-preview"  = 800_000
"qwen3.6-plus"            = 800_000
"qwen3.5-plus"            = 800_000
"minimax-m2.7"            = 196_608
"minimax-m2.5"            = 196_608
"kimi-k2.6"               = 256_000
"kimi-k2.5"               = 256_000
"gpt-5.5"                 = 400_000
"gpt-5.4"                 = 400_000
"gpt-5.4-mini"            = 400_000
"glm-5-turbo"             = 128_000
"glm-5"                   = 128_000
"glm-5.1"                 = 202_752
# Capital "GLM-5.1" is a separate case-sensitive key (ZEROCLAW_MODEL ships the
# model string as-is via env; model_windows.get() is case-sensitive). Same
# underlying ZhiPu GLM-5.1, same ~200K window — value verified 2026-06-02
# (OpenRouter z-ai/glm-5.1 = 202_752).
"GLM-5.1"                 = 202_752
"Qwen3.5-397B-A17B"       = 262_144

[skills]
prompt_injection_mode = "compact"

[observability]
backend = "none"
runtime_trace_mode = "rolling"
runtime_trace_path = "logs/runtime-trace.jsonl"
runtime_trace_max_entries = 500

[gateway]
port = 3000
host = "127.0.0.1"
require_pairing = false
allow_public_bind = false
paired_tokens = ["__ZEROCLAW_BEARER_TOKEN__"]
trust_forwarded_headers = false
pair_rate_limit_per_minute = 0
webhook_rate_limit_per_minute = 0
rate_limit_max_keys = 10000
idempotency_ttl_secs = 300
idempotency_max_keys = 10000

[tunnel]
provider = "none"

[channels_config]
cli = true

[channels_config.webhook]
port = 3000
secret = "__ZEROCLAW_WEBHOOK_SECRET__"

[autonomy]
level = "full"
workspace_only = false
allowed_commands = [
    "git",
    "npm",
    "cargo",
    "sh",
    "ls",
    "cat",
    "grep",
    "find",
    "echo",
    "pwd",
    "wc",
    "head",
    "tail",
    "date",
    "wget",
    "python3",
    "pip",
    "pip3",
    "node",
    "npx",
    "ffmpeg",
    "convert",
    "pandoc",
    "curl",
    "jq",
]
forbidden_paths = [
    "/etc",
    "/root",
    "/home",
    "/usr",
    "/bin",
    "/sbin",
    "/lib",
    "/opt",
    "/boot",
    "/dev",
    "/proc",
    "/sys",
    "/var",
    "/tmp",
    "~/.ssh",
    "~/.gnupg",
    "~/.aws",
    "~/.config",
    "/zeroclaw-data/mcp_graylog",
]
max_actions_per_hour = 20
max_cost_per_day_cents = 500
require_approval_for_medium_risk = false
block_high_risk_commands = false
shell_env_passthrough = ["NOTIFY_URL", "NOTIFY_SECRET", "NOTIFY_FILE_URL", "OPENROUTER_API_KEY", "CREATIO_BASE_URL", "CREATIO_USERNAME", "CREATIO_PASSWORD", "PG_PROD_HOST", "PG_PROD_PORT", "PG_PROD_USER", "PG_PROD_PASSWORD", "GITLAB_DEPLOY_USER", "GITLAB_DEPLOY_TOKEN", "GOOGLE_SERVICE_ACCOUNT_JSON", "SCRAPECREATORS_API_KEY", "XAI_API_KEY", "BRAVE_API_KEY", "JIRA_API_TOKEN", "JWT_SIGNING_SECRET"]
