"Qwen3.5-397B-A17B"       = 262_144

# Subagent runtime profile. Shares default's context_compression + model_windows
# so cross-model windows still resolve. Subagents do real work inside cron
# digests too, so they get the same generous budgets as the main profile.
[runtime_profiles.agent_default]
agentic = true
compact_context = false
max_tool_iterations = 200
max_actions_per_hour = 1_000_000
max_history_messages = 200
max_context_tokens = 128_000
parallel_tools = true
tool_dispatcher = "native"
shell_timeout_secs = 600

[runtime_profiles.agent_default.context_compression]
threshold_ratio = 0.70
protect_last_n = 10

