    "node",
    "npx",
    "ffmpeg",
    "convert",
    "pandoc",
    "curl",
    "jq",
    "agent-browser",
    "gh",
    "glab",
    "code_repos_sync.py",
]
forbidden_paths = [
    "/etc",
    "/root",
    "/home",
    "/usr",
    "/bin",
    "/sbin",
    "/lib",
    "/opt",
    "/boot",
    "/dev",
    "/proc",
    "/sys",
